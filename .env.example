# Copy to `.env.local` and fill in. Do not commit `.env.local` (see .gitignore).
# https://nextjs.org/docs/app/building-your-application/configuring/environment-variables

# Google Maps JavaScript API (enable Maps JavaScript API, Places, Geocoding in Google Cloud)
# Use either line (the app checks both):
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
# NEXT_PUBLIC_GOOGLE_API_KEY=
